# Copy to .env and adjust. NO secrets live here — users supply their
# Intervals.icu credentials per-request through the web form.

# Public port for the web app.
PORT=8080

# Comma-separated allowed origins for the API (leave empty if frontend proxies same-origin).
CORS_ORIGINS=

# Operational limits.
RUN_TIMEOUT=240
MAX_CONCURRENCY=2
RATE_LIMIT=5/hour

# Set to 1 only for E2E/CI: skips the real fetch+plot and returns a stub package.
MOCK_FETCH=0
