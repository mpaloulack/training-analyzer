# Copy to .env (next to docker-compose.deploy.yml) and adjust.
# Compose reads .env automatically:  docker compose -f docker-compose.deploy.yml up -d
#
# NO secrets here — users supply their Intervals.icu credentials per request
# through the web form. These are operational settings only.

# Released image version to run (matches a v<TAG> git tag). "latest" = newest release.
TAG=1.0.0

# Public port for the web UI.
PORT=8080

# Allowed CORS origins for the API. Leave empty when the bundled nginx proxies
# the API same-origin (the default setup). Set to your site, e.g. https://app.example.com
CORS_ORIGINS=

# Abuse / load limits.
RATE_LIMIT=5/hour          # per client IP, on the run endpoint
MAX_CONCURRENCY=2          # simultaneous analyses (returns 503 when full)
RUN_TIMEOUT=240            # seconds before a runaway run is killed

# Override only if you mirror the images to another registry.
# Final names are <IMAGE_REPO>-backend:<TAG> and <IMAGE_REPO>-frontend:<TAG>.
IMAGE_REPO=ghcr.io/yourUsername/yourRepoName

# Testing only: 1 = skip the real Intervals.icu fetch and return stub data.
# Leave 0 (or unset) in production.
MOCK_FETCH=0
